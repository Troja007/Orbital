# Copy this file to orbital_credentials.env and fill in local values.
# Never commit real tokens, client IDs, or client secrets.

# Orbital API region: eu, na, us, or apjc
ORBITAL_REGION=eu

# Option A: use an existing bearer token.
# ORBITAL_API_TOKEN=

# Option B: let the import script request a bearer token from client credentials.
# ORBITAL_CLIENT_ID=
# ORBITAL_CLIENT_SECRET=
