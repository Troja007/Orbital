# Legacy fallback example only. Prefer the global Codex ORG Mapping
# source_env_file for normal Orbital workflows.
# Never commit real tokens, client IDs, or client secrets.

# Orbital API region: eu, na, us, or apjc
ORBITAL_REGION=eu

# The selected Codex ORG Mapping state selects the credential env file and,
# therefore, the effective Orbital tenant. ORG context alone cannot switch it.
# By default, the helper reads the mapping and its source_env_file:
# ~/.codex/state/cisco-security-api-access/current_org_mapping.json
# ORBITAL_ORG_MAPPING_STATE_FILE=/Users/<user>/.codex/state/cisco-security-api-access/current_org_mapping.json
# ORBITAL_ENV_FILE=/absolute/path/to/explicit/credential.env
#
# Optional local ORG metadata. ORBITAL_ORG_GROUP must match the selected
# mapping_alias. Prefer product-qualified ORG entries when needed.
# ORBITAL_ORG_GROUP=example-lab
# ORBITAL_ORGS=edr:<org>,xdr:<org>,orbital:<org>
# ORBITAL_ORG_CONTEXT_FILE=local/orbital_query_runs/org_context.json

# Option A: use an existing bearer token.
# ORBITAL_API_TOKEN=
# SECURE_ENDPOINT_BEARER_TOKEN=
# AMP_BEARER_TOKEN=
# BEARER_TOKEN=

# Option B: let the import script request a bearer token from client credentials.
# ORBITAL_CLIENT_ID=
# ORBITAL_CLIENT_SECRET=
# SECURE_ENDPOINT_V3_OAUTH_CLIENT_ID=
# SECURE_ENDPOINT_V3_OAUTH_CLIENT_SECRET=
# SECURE_ENDPOINT_V3_VISIBILITY_TOKEN_URL=
